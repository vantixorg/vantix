diff --git a/servers/rendering/renderer_rd/shaders/forward_clustered/scene_forward_clustered.glsl b/servers/rendering/renderer_rd/shaders/forward_clustered/scene_forward_clustered.glsl
index 740f77d0..6445d5a9 100644
--- a/servers/rendering/renderer_rd/shaders/forward_clustered/scene_forward_clustered.glsl
+++ b/servers/rendering/renderer_rd/shaders/forward_clustered/scene_forward_clustered.glsl
@@ -2616,11 +2616,30 @@ void fragment_shader(in SceneData scene_data) {
 
 			float size_A = sc_use_directional_soft_shadows() ? directional_lights.data[i].size : 0.0;
 
+			vec3 directional_color = directional_lights.data[i].color * directional_lights.data[i].energy;
+
+			if (directional_lights.data[i].projector_rect != vec4(0.0)) {
+				vec4 atlas_rect = directional_lights.data[i].projector_rect;
+				vec2 puv = (directional_lights.data[i].projector_matrix * vec4(vertex, 1.0)).xy;
+				vec2 proj_uv = fract(puv) * atlas_rect.zw + atlas_rect.xy;
+
+				// Always sample with explicit gradients so the projector gets proper
+				// trilinear/anisotropic filtering at grazing angles (no spec constant:
+				// use_light_projector is only set by omni/spot pairing). Derivatives come
+				// from the unwrapped uv so fract() seams don't spike the mip level.
+				vec2 puv_ddx = (directional_lights.data[i].projector_matrix * vec4(vertex + vertex_ddx, 1.0)).xy;
+				vec2 puv_ddy = (directional_lights.data[i].projector_matrix * vec4(vertex + vertex_ddy, 1.0)).xy;
+				vec2 proj_uv_ddx = (puv_ddx - puv) * atlas_rect.zw;
+				vec2 proj_uv_ddy = (puv_ddy - puv) * atlas_rect.zw;
+				vec4 proj = textureGrad(sampler2D(decal_atlas_srgb, light_projector_sampler), proj_uv, proj_uv_ddx, proj_uv_ddy);
+				directional_color *= proj.rgb * proj.a;
+			}
+
 			light_compute(normal, directional_lights.data[i].direction, normalize(view), size_A,
 #ifndef DEBUG_DRAW_PSSM_SPLITS
-					directional_lights.data[i].color * directional_lights.data[i].energy,
+					directional_color,
 #else
-					directional_lights.data[i].color * directional_lights.data[i].energy * tint,
+					directional_color * tint,
 #endif
 					true, shadow, f0, roughness, metallic, directional_lights.data[i].specular, albedo, alpha, screen_uv, energy_compensation,
 #ifdef LIGHT_BACKLIGHT_USED
diff --git a/servers/rendering/renderer_rd/shaders/light_data_inc.glsl b/servers/rendering/renderer_rd/shaders/light_data_inc.glsl
index edfe777d..443a599e 100644
--- a/servers/rendering/renderer_rd/shaders/light_data_inc.glsl
+++ b/servers/rendering/renderer_rd/shaders/light_data_inc.glsl
@@ -84,4 +84,6 @@ struct DirectionalLightData {
 	vec2 uv_scale2;
 	vec2 uv_scale3;
 	vec2 uv_scale4;
+	vec4 projector_rect; // projector rect in srgb decal atlas (zero = no projector)
+	mat4 projector_matrix; // view-space vertex -> tiled projector uv
 };
diff --git a/servers/rendering/renderer_rd/storage_rd/light_storage.cpp b/servers/rendering/renderer_rd/storage_rd/light_storage.cpp
index 0c716857..ca23592a 100644
--- a/servers/rendering/renderer_rd/storage_rd/light_storage.cpp
+++ b/servers/rendering/renderer_rd/storage_rd/light_storage.cpp
@@ -240,18 +240,16 @@ void LightStorage::light_set_projector(RID p_light, RID p_texture) {
 
 	ERR_FAIL_COND(p_texture.is_valid() && !texture_storage->owns_texture(p_texture));
 
-	if (light->type != RS::LIGHT_DIRECTIONAL && light->projector.is_valid()) {
+	if (light->projector.is_valid()) {
 		texture_storage->texture_remove_from_decal_atlas(light->projector, light->type == RS::LIGHT_OMNI);
 	}
 
 	light->projector = p_texture;
 
-	if (light->type != RS::LIGHT_DIRECTIONAL) {
-		if (light->projector.is_valid()) {
-			texture_storage->texture_add_to_decal_atlas(light->projector, light->type == RS::LIGHT_OMNI);
-		}
-		light->dependency.changed_notify(Dependency::DEPENDENCY_CHANGED_LIGHT_SOFT_SHADOW_AND_PROJECTOR);
+	if (light->projector.is_valid()) {
+		texture_storage->texture_add_to_decal_atlas(light->projector, light->type == RS::LIGHT_OMNI);
 	}
+	light->dependency.changed_notify(Dependency::DEPENDENCY_CHANGED_LIGHT_SOFT_SHADOW_AND_PROJECTOR);
 }
 
 void LightStorage::light_set_negative(RID p_light, bool p_enable) {
@@ -691,6 +689,35 @@ void LightStorage::update_light_buffers(RenderDataRD *p_render_data, const Paged
 
 				light_data.bake_mode = light->bake_mode;
 
+				// Light projector (e.g. drifting cloud cookie). Unlike stock Godot, directional
+				// lights are registered in the decal atlas, so the cookie modulates only the
+				// real-time sun contribution and respects the shadow map.
+				RID projector = light->projector;
+				if (projector.is_valid()) {
+					Rect2 rect = texture_storage->decal_atlas_get_texture_rect(projector);
+					light_data.projector_rect[0] = rect.position.x;
+					light_data.projector_rect[1] = rect.position.y;
+					light_data.projector_rect[2] = rect.size.width;
+					light_data.projector_rect[3] = rect.size.height;
+
+					const float projector_tile_size = light->param[RS::LIGHT_PARAM_PROJECTOR_TILE_SIZE];
+					const float projector_world_scale = projector_tile_size > 0.0 ? 1.0 / projector_tile_size : 0.025;
+					const Vector2 projector_wind = Vector2(light->param[RS::LIGHT_PARAM_PROJECTOR_WIND_X], light->param[RS::LIGHT_PARAM_PROJECTOR_WIND_Y]);
+					float ptime = p_render_data->scene_data ? p_render_data->scene_data->time : 0.0;
+					Transform3D to_light = light_transform.affine_inverse(); // world -> light local
+					Transform3D view_to_world = inverse_transform.affine_inverse(); // view -> world
+					Transform3D uv_xform;
+					uv_xform.basis.scale(Vector3(projector_world_scale, projector_world_scale, 1.0));
+					uv_xform.origin = Vector3(0.5 + projector_wind.x * ptime, 0.5 + projector_wind.y * ptime, 0.0);
+					Projection projector_matrix = Projection(uv_xform * to_light * view_to_world);
+					RendererRD::MaterialStorage::store_camera(projector_matrix, light_data.projector_matrix);
+				} else {
+					light_data.projector_rect[0] = 0;
+					light_data.projector_rect[1] = 0;
+					light_data.projector_rect[2] = 0;
+					light_data.projector_rect[3] = 0;
+				}
+
 				if (light_data.shadow_opacity > 0.001) {
 					RS::LightDirectionalShadowMode smode = light->directional_shadow_mode;
 
