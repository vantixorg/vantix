From: VANTIX project local patch
Subject: [PATCH] Directional light projectors (cloud-shadow cookies)

Stock Godot supports light_projector only for omni/spot lights; this adds it
for DirectionalLight3D so a drifting cloud cookie can darken only the
real-time sun contribution and respect the shadow map (only inside window
light-shafts, not lamp-lit floor).

- register directional projectors in the decal atlas
- DirectionalLightData gains projector_rect + a view->light-plane
  projector_matrix (C++ + GLSL, std140-aligned tail fields)
- clustered directional loop samples the cookie with anisotropic textureGrad,
  multiplies sun color (runtime-gated by projector_rect, no spec constant)
- expose light_projector in the DirectionalLight3D inspector
- per-light tuning via new light params PROJECTOR_WIND_X/Y (cookie drift,
  tiles/sec) and PROJECTOR_TILE_SIZE (world units per tile); projector_matrix
  applies a time-based wind offset. Defaults 0.012/0.006/40. Per-map, set in
  the light's "Cloud Projector" inspector group. Forward+ only.

Patch
-----

diff --git a/scene/3d/light_3d.cpp b/scene/3d/light_3d.cpp
index 2f7d55fc..3641cc03 100644
--- a/scene/3d/light_3d.cpp
+++ b/scene/3d/light_3d.cpp
@@ -398,6 +398,11 @@ void Light3D::_bind_methods() {
 	ADD_PROPERTY(PropertyInfo(Variant::INT, "light_bake_mode", PROPERTY_HINT_ENUM, "Disabled,Static,Dynamic"), "set_bake_mode", "get_bake_mode");
 	ADD_PROPERTY(PropertyInfo(Variant::INT, "light_cull_mask", PROPERTY_HINT_LAYERS_3D_RENDER), "set_cull_mask", "get_cull_mask");
 
+	ADD_GROUP("Cloud Projector", "cloud_projector_");
+	ADD_PROPERTYI(PropertyInfo(Variant::FLOAT, "cloud_projector_wind_x", PROPERTY_HINT_RANGE, "-1,1,0.0001,or_greater,or_less"), "set_param", "get_param", PARAM_PROJECTOR_WIND_X);
+	ADD_PROPERTYI(PropertyInfo(Variant::FLOAT, "cloud_projector_wind_y", PROPERTY_HINT_RANGE, "-1,1,0.0001,or_greater,or_less"), "set_param", "get_param", PARAM_PROJECTOR_WIND_Y);
+	ADD_PROPERTYI(PropertyInfo(Variant::FLOAT, "cloud_projector_tile_size", PROPERTY_HINT_RANGE, "1,400,0.5,or_greater,suffix:m"), "set_param", "get_param", PARAM_PROJECTOR_TILE_SIZE);
+
 	ADD_GROUP("Shadow", "shadow_");
 	ADD_PROPERTY(PropertyInfo(Variant::BOOL, "shadow_enabled", PROPERTY_HINT_GROUP_ENABLE), "set_shadow", "has_shadow");
 	ADD_PROPERTYI(PropertyInfo(Variant::FLOAT, "shadow_bias", PROPERTY_HINT_RANGE, "0,10,0.001"), "set_param", "get_param", PARAM_SHADOW_BIAS);
@@ -440,6 +445,9 @@ void Light3D::_bind_methods() {
 	BIND_ENUM_CONSTANT(PARAM_SHADOW_BLUR);
 	BIND_ENUM_CONSTANT(PARAM_TRANSMITTANCE_BIAS);
 	BIND_ENUM_CONSTANT(PARAM_INTENSITY);
+	BIND_ENUM_CONSTANT(PARAM_PROJECTOR_WIND_X);
+	BIND_ENUM_CONSTANT(PARAM_PROJECTOR_WIND_Y);
+	BIND_ENUM_CONSTANT(PARAM_PROJECTOR_TILE_SIZE);
 	BIND_ENUM_CONSTANT(PARAM_MAX);
 
 	BIND_ENUM_CONSTANT(BAKE_DISABLED);
@@ -493,6 +501,9 @@ Light3D::Light3D(RenderingServer::LightType p_type) {
 	set_param(PARAM_SHADOW_FADE_START, 1);
 	// For OmniLight3D and SpotLight3D, specified in Lumens.
 	set_param(PARAM_INTENSITY, 1000.0);
+	set_param(PARAM_PROJECTOR_WIND_X, 0.012);
+	set_param(PARAM_PROJECTOR_WIND_Y, 0.006);
+	set_param(PARAM_PROJECTOR_TILE_SIZE, 40.0);
 	set_temperature(6500.0); // Nearly white.
 	set_disable_scale(true);
 }
@@ -552,7 +563,7 @@ void DirectionalLight3D::_validate_property(PropertyInfo &p_property) const {
 			p_property.usage = PROPERTY_USAGE_NO_EDITOR;
 		}
 	}
-	if (p_property.name == "light_size" || p_property.name == "light_projector") {
+	if (p_property.name == "light_size") {
 		// Not implemented in DirectionalLight3D (`light_size` is replaced by `light_angular_distance`).
 		p_property.usage = PROPERTY_USAGE_NONE;
 	}
