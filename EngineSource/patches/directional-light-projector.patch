diff --git a/servers/rendering/renderer_rd/shaders/forward_clustered/scene_forward_clustered.glsl b/servers/rendering/renderer_rd/shaders/forward_clustered/scene_forward_clustered.glsl
index 431f480..6350b3d 100644
--- a/servers/rendering/renderer_rd/shaders/forward_clustered/scene_forward_clustered.glsl
+++ b/servers/rendering/renderer_rd/shaders/forward_clustered/scene_forward_clustered.glsl
@@ -2662,11 +2662,36 @@ void fragment_shader(in SceneData scene_data) {
 
 			float size_A = sc_use_directional_soft_shadows() ? directional_lights.data[i].size : 0.0;
 
+			vec3 directional_color = directional_lights.data[i].color * directional_lights.data[i].energy;
+
+			if (directional_lights.data[i].projector_rect != vec4(0.0)) {
+				vec4 atlas_rect = directional_lights.data[i].projector_rect;
+				vec2 puv = (directional_lights.data[i].projector_matrix * vec4(vertex, 1.0)).xy;
+				vec2 atlas_texels = vec2(textureSize(sampler2D(decal_atlas, light_projector_sampler), 0));
+				vec2 tile_texels = atlas_rect.zw * atlas_texels;
+				vec2 tc = fract(puv) * tile_texels - 0.5;
+				vec2 tc_fl = floor(tc);
+				vec2 tc_fr = tc - tc_fl;
+				vec2 inv_atlas = 1.0 / atlas_texels;
+				vec2 uv00 = atlas_rect.xy + (mod(tc_fl, tile_texels) + 0.5) * inv_atlas;
+				vec2 uv10 = atlas_rect.xy + (mod(tc_fl + vec2(1.0, 0.0), tile_texels) + 0.5) * inv_atlas;
+				vec2 uv01 = atlas_rect.xy + (mod(tc_fl + vec2(0.0, 1.0), tile_texels) + 0.5) * inv_atlas;
+				vec2 uv11 = atlas_rect.xy + (mod(tc_fl + vec2(1.0, 1.0), tile_texels) + 0.5) * inv_atlas;
+				vec4 s00 = textureLod(sampler2D(decal_atlas, light_projector_sampler), uv00, 0.0);
+				vec4 s10 = textureLod(sampler2D(decal_atlas, light_projector_sampler), uv10, 0.0);
+				vec4 s01 = textureLod(sampler2D(decal_atlas, light_projector_sampler), uv01, 0.0);
+				vec4 s11 = textureLod(sampler2D(decal_atlas, light_projector_sampler), uv11, 0.0);
+				vec4 proj = mix(mix(s00, s10, tc_fr.x), mix(s01, s11, tc_fr.x), tc_fr.y);
+				vec3 cookie = proj.rgb * proj.a;
+				float cookie_amount = directional_lights.data[i].projector_params.x * shadow;
+				directional_color *= mix(vec3(1.0), cookie, cookie_amount);
+			}
+
 			light_compute(normal, directional_lights.data[i].direction, normalize(view), size_A,
 #ifndef DEBUG_DRAW_PSSM_SPLITS
-					directional_lights.data[i].color * directional_lights.data[i].energy,
+					directional_color,
 #else
-					directional_lights.data[i].color * directional_lights.data[i].energy * tint,
+					directional_color * tint,
 #endif
 					true, shadow, f0, roughness, metallic, directional_lights.data[i].specular, albedo, alpha, screen_uv, energy_compensation,
 #ifdef LIGHT_BACKLIGHT_USED
