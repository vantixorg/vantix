From: VANTIX project local patch
Subject: [PATCH] Directional light projectors (cloud-shadow cookies)

Adds light_projector to DirectionalLight3D (stock Godot only does omni/spot): a drifting
cloud cookie dims only the real-time sun and respects the shadow map. New light params
PROJECTOR_WIND_X/Y, PROJECTOR_TILE_SIZE, PROJECTOR_STRENGTH (Cloud Projector group). Forward+, 4.7.

Patch
-----

diff --git a/scene/3d/light_3d.cpp b/scene/3d/light_3d.cpp
index 8dccf8b..94561ab 100644
--- a/scene/3d/light_3d.cpp
+++ b/scene/3d/light_3d.cpp
@@ -411,6 +411,12 @@ void Light3D::_bind_methods() {
 	ADD_PROPERTY(PropertyInfo(Variant::INT, "light_bake_mode", PROPERTY_HINT_ENUM, "Disabled,Static,Dynamic"), "set_bake_mode", "get_bake_mode");
 	ADD_PROPERTY(PropertyInfo(Variant::INT, "light_cull_mask", PROPERTY_HINT_LAYERS_3D_RENDER), "set_cull_mask", "get_cull_mask");
 
+	ADD_GROUP("Cloud Projector", "cloud_projector_");
+	ADD_PROPERTYI(PropertyInfo(Variant::FLOAT, "cloud_projector_wind_x", PROPERTY_HINT_RANGE, "-1,1,0.0001,or_greater,or_less"), "set_param", "get_param", PARAM_PROJECTOR_WIND_X);
+	ADD_PROPERTYI(PropertyInfo(Variant::FLOAT, "cloud_projector_wind_y", PROPERTY_HINT_RANGE, "-1,1,0.0001,or_greater,or_less"), "set_param", "get_param", PARAM_PROJECTOR_WIND_Y);
+	ADD_PROPERTYI(PropertyInfo(Variant::FLOAT, "cloud_projector_tile_size", PROPERTY_HINT_RANGE, "1,400,0.5,or_greater,suffix:m"), "set_param", "get_param", PARAM_PROJECTOR_TILE_SIZE);
+	ADD_PROPERTYI(PropertyInfo(Variant::FLOAT, "cloud_projector_strength", PROPERTY_HINT_RANGE, "0,1,0.001"), "set_param", "get_param", PARAM_PROJECTOR_STRENGTH);
+
