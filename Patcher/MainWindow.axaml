<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="https://github.com/whistyun/Markdown.Avalonia"
        x:Class="Vantix.Patcher.MainWindow"
        Title="VANTIX Launcher"
        Icon="/Assets/logo.png"
        Width="780" Height="560"
        MinWidth="560" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        Background="#0E0F13">

  <Grid RowDefinitions="Auto,*,Auto,Auto,Auto" Margin="24">

    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="14" Margin="0,0,0,16">
      <Image x:Name="Logo" Height="48" Stretch="Uniform" />
      <TextBlock x:Name="TitleFallback"
                 Text="VANTIX"
                 FontSize="30" FontWeight="Bold"
                 Foreground="#F2F3F5"
                 VerticalAlignment="Center"
                 IsVisible="False" />
    </StackPanel>

    <Border Grid.Row="1"
            Background="#15171C"
            CornerRadius="6"
            Padding="16"
            Margin="0,0,0,16">
      <md:MarkdownScrollViewer x:Name="Changelog" />
    </Border>

    <TextBlock Grid.Row="2"
               x:Name="StatusText"
               Text="Starting..."
               Foreground="#9AA0A6"
               FontSize="13"
               Margin="0,0,0,8" />

    <ProgressBar Grid.Row="3"
                 x:Name="Progress"
                 Minimum="0" Maximum="100" Value="0"
                 Height="6"
                 Foreground="#5865F2"
                 Background="#23252B"
                 Margin="0,0,0,16" />

    <Button Grid.Row="4"
            x:Name="PlayButton"
            Content="PLAY"
            IsEnabled="False"
            Click="OnPlayClicked"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Center"
            Height="44"
            FontSize="16" FontWeight="SemiBold"
            Foreground="White"
            Background="#5865F2" />
  </Grid>
</Window>
