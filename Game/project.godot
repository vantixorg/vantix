[layer_names]

3d_render/layer_1="World"
3d_render/layer_2="FPS"
3d_physics/layer_1="WORLD"
3d_physics/layer_2="FPS"
3d_physics/layer_3="HITBOX"
3d_physics/layer_4="DEBRIS"
3d_physics/layer_5="SERVER"

[physics]

common/physics_ticks_per_second=128
3d/physics_engine="Jolt Physics"
jolt_physics_3d/queries/use_enhanced_internal_edge_removal=true
jolt_physics_3d/limits/temporary_memory_buffer_size=8
jolt_physics_3d/limits/max_bodies=4096
jolt_physics_3d/limits/max_body_pairs=8192
jolt_physics_3d/limits/max_contact_constraints=4096

[rendering]

rendering_device/driver.windows="d3d12"
reflections/reflection_atlas/reflection_size=512
reflections/reflection_atlas/reflection_count=32
occlusion_culling/occlusion_rays_per_thread=256
limits/cluster_builder/max_clustered_elements=1024.0
anti_aliasing/quality/use_taa=true
occlusion_culling/use_occlusion_culling=true
mesh_lod/lod_change/threshold_pixels=2.5
2d/snap/snap_2d_transforms_to_pixel=true
lights_and_shadows/positional_shadow/atlas_size=2048
