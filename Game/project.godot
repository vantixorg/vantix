; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="VANTIX"
config/version="0.0.1"
run/main_scene="uid://cui7t1hv14rgl"
config/quit_on_go_back=false
config/features=PackedStringArray("4.6", "C#", "Forward Plus")
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/stretch_mode=0
boot_splash/image="uid://d1jshvl3xx067"
config/icon="uid://cac5otb0sckp3"

[autoload]

NetMain="*res://codebase/net/NetMain.cs"
ProcessPriorityBoost="*res://codebase/platform/ProcessPriorityBoost.cs"
WorldFadeOverlay="*res://codebase/world/WorldFadeOverlay.cs"

[debug]

settings/profiler/max_timestamp_query_elements=2048

[display]

window/vsync/vsync_mode=0

[dotnet]

project/assembly_name="vantix"

[editor_plugins]

enabled=PackedStringArray("res://addons/spots_gizmo/plugin.cfg")

[global]

debug=false

[global_group]

concrete=""
metal=""
sand=""
dirt=""
mud=""
grass=""
gravel=""
wood=""
bombsite_a=""
bombsite_b=""
spawn_ct=""
spawn_t=""
spawn_deathmatch=""
preview_cam=""
wallhit=""

